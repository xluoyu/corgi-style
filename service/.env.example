# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=outfit_agent

# Application Configuration
APP_ENV=development
LOG_LEVEL=info

# LLM Provider Configuration
LLM_PROVIDER=local  # openai, anthropic, local
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus  # 通用大模型
VISION_MODEL=qwen-vl-plus-2025-01-08  # 视觉大模型
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# OSS Configuration
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_CDN_DOMAIN=your_bucket_name.oss-cn-hangzhou.aliyuncs.com
OSS_URL_EXPIRE_SECONDS=3600

# Qwen-Image-2.0 生图 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key

# Remove.bg API (for background removal)
PEXELS_API_KEY=your_rembg_api_key
