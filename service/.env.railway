# =============================================
# Railway 部署环境变量
# =============================================
# Railway 会自动设置 DATABASE_URL（指向托管 PostgreSQL）
# 以下变量需要在 Railway Dashboard 或 .env 文件中手动配置

# LLM 服务（通义千问）
OPENAI_API_KEY=your_qwen_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云 OSS（用于图片存储）
OSS_ACCESS_KEY_ID=your_oss_key_id
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://your_cdn_domain.com

# Pexels API（穿搭图片搜索，可选）
PEXELS_API_KEY=your_pexels_api_key

# 前端域名（用于 CORS，部署后替换）
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-app.vercel.app
